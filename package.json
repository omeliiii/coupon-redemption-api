{
  "name": "coupon-redemption-api",
  "version": "1.0.0",
  "description": "REST API for a coupon redemption system",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omeliiii/coupon-redemption-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/omeliiii/coupon-redemption-api/issues"
  },
  "homepage": "https://github.com/omeliiii/coupon-redemption-api#readme",
  "dependencies": {
    "fastify": "^5.3.3",
    "fastify-type-provider-zod": "^4.0.2",
    "kysely": "^0.27.6",
    "pg": "^8.14.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.13",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
